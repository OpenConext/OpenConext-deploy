systemLog:
  destination: syslog

net:
  bindIp: {{ mongo_bind_listen_address }}
  port: 27017
  tls:
    mode: preferTLS
    disabledProtocols: TLS1_0,TLS1_1,TLS1_2
    certificateKeyFile: /etc/pki/mongo/keyandcert.pem
    CAFile: /etc/pki/mongo/mongoca.pem
    allowConnectionsWithoutCertificates: true

storage:
  dbPath: {{ mongo_data_path }}

{% if mongo_replica_set_name is defined and mongo_mode == "cluster" %}
replication:
  replSetName: {{ mongo_replica_set_name }}
{% endif %}

security:
    authorization: enabled
    clusterAuthMode: x509
    javascriptEnabled: false
